# Terraform working/cache files
.terraform/

# Terraform state can contain secrets and infrastructure details
terraform.tfstate
terraform.tfstate.*

# Local variable files can contain API tokens/secrets
terraform.tfvars
terraform.tfvars.example
*.auto.tfvars

# Terraform crash logs and saved plans can contain sensitive values
crash.log
crash.*.log
*.tfplan
*.plan

# Local environment/secrets
.env
.env.*
*.pem
*.key
id_rsa
id_ed25519
*_rsa
*_ed25519

# macOS/editor noise
.DS_Store
.vscode/
.idea/
